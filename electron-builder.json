{
  "appId": "com.venmurasu.app",
  "productName": "Venmurasu",
  "copyright": "Copyright © 2025 Venmurasu",
  "directories": {
    "output": "dist-electron",
    "buildResources": "public"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "zip",
        "arch": ["x64"]
      }
    ],
    "icon": "public/icon.png"
  },
  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Venmurasu"
  },
  "mac": {
    "target": "dmg",
    "icon": "public/icon.png"
  },
  "linux": {
    "target": "AppImage",
    "icon": "public/icon.png"
  }
}
